package com.Serailization;

import java.io.File;
import java.io.FileInputStream;
import java.io.FileNotFoundException;
import java.io.FileOutputStream;
import java.io.IOException;
import java.io.ObjectInputStream;
import java.io.ObjectOutputStream;
import java.io.Serializable;
import java.util.Scanner;

class DemoClass implements Serializable{

	final static long serialVersionUID = 1234567890987L;     // we should assing that UID
	private String name ;
	private int age;
	private long AccNo;
	private long AccBal;

	public DemoClass(String name, int age, long accNo, long accBal) {
		
		this.name = name;
		this.age = age;
		AccNo = accNo;
		AccBal = accBal;
		
	}
	
	public String Gettername() {
		
		return name;
	}
	
	public int GetterAge() {
		
		return age;
	}
	
	public long GetterAccno() {
		return AccNo;
	}
	
	public long GetterBal() {
		
		return AccBal;
	}	
}

class DemoClass1{
	Scanner scan = new Scanner(System.in);
	
	Object demo1() {
		
		DemoClass d= new DemoClass("manohar", 22, 14501000063366L, 50000);
		return d;
	}
}

class DemoClass2{
	
	FileOutputStream fs=null;
	ObjectOutputStream oo= null;
	
	void demo1() {
		
		try {
			DemoClass1 DC = new DemoClass1();
			Object obj = DC.demo1();
			fs= new FileOutputStream ("D:\\Folder2\\file1.txt");
			oo= new ObjectOutputStream (fs);
			oo.writeObject(obj);
			oo.close();
		} 
		catch (FileNotFoundException e) {
			
			e.printStackTrace();
		}
		catch (IOException e) {
			
			e.printStackTrace();
		}
	}	
}

class DemoClass3{
				
	FileInputStream FI=null;
	ObjectInputStream Ob=null;
	
	void demo1() {
		
		try {
			
			 FI = new FileInputStream("D:\\Folder2\\file1.txt");
			 Ob= new ObjectInputStream(FI);
			 DemoClass info =( DemoClass ) Ob.readObject();		// #downcasting
			 System.out.println(info.Gettername());
			 System.out.println(info.GetterAge());
			 System.out.println(info.GetterAccno());
			 System.out.println(info.GetterBal());
		
			 
		}
		catch (IOException e) {
		
			e.printStackTrace();
		}
		catch(Exception a) {
			
			a.printStackTrace();
		}
	}
}
