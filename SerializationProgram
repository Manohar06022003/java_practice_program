	public static void main (String[] args ) {
		
		try {
					
		File f = new File("D:\\Folder2");
		f.mkdir();
		File f2 = new File ("D:\\Folder2\\file1.txt");
		f2.createNewFile();
		
		new DemoClass2().demo1();
		new DemoClass3().demo1();
		}
		catch(Exception e) {
			
			e.printStackTrace();
		}
	}

}
