package com.Multithreading;

import java.util.Scanner;

class demo extends Thread{
	
	 Scanner scan =new Scanner(System.in);

	public void run() {
		Thread th= Thread.currentThread();		//to find current thread is running.eg: main thread or we created thread.
		String name=th.getName();				//precisely get current thread name for multithreading
		 if (name.equals("add")) {
			 run1();
		 }
		 else if (name.equals("print")) {
			 run2();
		 }
		 else {
			 run3();
		 }
		
	 }
	 
	 public void run1() {
		 int a,b,c;
			a=scan.nextInt();
			b=scan.nextInt();
			c=a+b;
			System.out.println(c);
			try {
				Thread.sleep(2000);
			}
			catch(Exception a1) {
				System.out.println("handled");
			}		
		 
	 }
	 
	 public void run2() {
		 for (int i=65;i<=75;i++) {
				System.out.println((char)i);
				try {
					Thread.sleep(2000);
				} catch (InterruptedException e) {
				
					e.printStackTrace();
				}
		 }
	 }
	 
	 public void run3() {
		 for (int i=65 ; i <= 75 ; i++) {
			 char a=(char)i;
			 char b=Character.toLowerCase(a);
			 System.out.println(b);
			 
		 }
	 }
 }
 
public class MultiThreading2 {
	public static void main(String[] args) {
		
		 demo d1=new demo();				//CREATE THE 3CLASS OBJECT FOR 3STACK FRAME TO ARCJIVE THE MULTTHREADING
		 demo d2=new demo();
		 demo d3=new demo();
		 d1.setName("add");
		 d2.setName("print");				//SET THE NAME FOR 3 THREADS TO ACCESS ,to decide which task going to run.
		 d3.setName("print1");
		 d1.start();
		 d2.start();
		 d3.start();
	}

}
