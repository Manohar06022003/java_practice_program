package com.practiceSession;

import java.util.Scanner;

class InvalidInputException extends Exception{
	
	InvalidInputException(){
		super("Numbers are not allowed, please try again later✨");
	}
}
class FindVowels{
	
	String Word;
	String Word2;
	int count =0 ;
	int Size;
	char a;
	
	FindVowels(String Word){
		
		this.Word = Word;
		
	}
	
	void checkWord() {
		Word2=Word.toLowerCase();
		Size =Word.length();
		for ( int i =0 ; i < Size ; i++) {
			
			a = Word2.charAt(i);
			
			if ( a == 'a' || a == 'e' || a == 'i' || a == 'o' || a == 'u' ) {
				
				count++;
			}
		}
		System.out.println("number of vowels are present in the word is : "+count);
	}
}

class GetData{
	
	Scanner scan = new Scanner(System.in);
	
	void getData() {
		
		try {
			
			System.out.print("Enter the words : ");
			String s= scan.nextLine();
			if (!s.matches("[a-zA-Z]+")) {
				
				throw new InvalidInputException();
			}
				
			new FindVowels(s).checkWord();
			
		}
		catch(InvalidInputException a) {
			
			System.out.println(a.getMessage());
		}	
	}
}
public class PracticeProgram2 {
	public static void main (String [] args) {
		
		new GetData().getData();
	}
}

