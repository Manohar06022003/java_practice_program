package practiceSeccession;

class pattern2{
	 
	void pattern() {
		
		for (int i =1 ; i<=5 ; i++) {
			
			System.out.println();
			for ( int j = 1 ; j <= 5 ; j++) {
				
				if (i==1 || i == 5 || j==1 || j==5) {
					
					System.out.print("*");
				}
	
				else{
					
					System.out.print(" "); 
					
				}
				
			}	
		}
	}
}
public class pattern_program1 {
	public static void main(String [] args) {
		new pattern2().pattern();
	}

}
