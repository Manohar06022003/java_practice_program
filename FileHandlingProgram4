			FileReader f2 = new FileReader("D:\\ManoFolder3\\b.txt");
			BufferedReader Buffer2 = new BufferedReader(f2);
			String s;
			String numbers;
			
			while((s=Buffer1.readLine()) != null && (numbers= Buffer2.readLine()) != null) {
				
