import java.util.InputMismatchException;
import java.util.Scanner;

class InvalidException extends Exception {
	InvalidException(){
		
		super("Name should be in alphats");
		
		}
}
class bankDetails{
	
	private String name;
	private long accNo;
	private long balance=10000000;
	
	bankDetails(String name, long accNo){
		
		this.name = name;
		this.accNo = accNo;
		
	}
	String nameHolderGetter() {
		
		return name;
		
	}
	long accNoGetter() {
		
		return accNo;
	}
	long balanceGetter() {
		
		return balance;
	}
	void depositAmount(long balance1) {
		
		balance = balance1+balance;
		System.out.println("Deposited successfully");
		
	}
	void WithDrawal(long amount) {
		
		long a=amount ;
		if (a<=balance) {
			
			balance=balance-a;
			System.out.println("WithDraw is completed");
			
		}
		else {
			System.out.println("Insufficent balance");
		}
	}
}

class functionOfBank extends bankDetails{
	
	Scanner scan = new Scanner (System.in);

	functionOfBank(String name, long accNo) {
		super(name, accNo );
		
	}
	
	void deposits() {
		try {
			
			System.out.print("Enter a deposit Amount : ");
			long amount= scan.nextLong();
			depositAmount(amount);
			
		}
		catch(InputMismatchException e) {
			
			e.printStackTrace();
			System.out.println("Enter only numbers");
			
		}
	}
	
	void withDraws() {
		
		try {
			
			System.out.print("Enter  a withDraw amount : ");
			long amount = scan.nextLong();
			WithDrawal(amount);
		}
		catch(InputMismatchException a) {
			
			a.printStackTrace();
			System.out.println("Enter only numbers");
		}
	}
	
