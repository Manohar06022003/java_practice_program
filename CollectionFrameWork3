class ArrayDeque1 implements Runnable{
	 public void run() {
		 synchronized (CommonLock.Lock) {
				deque();
			}
	}
	
	void deque() {
		
		ArrayDeque<Integer> deque = new ArrayDeque<>();
		deque. add(30);
		deque.add(40);
		deque.add(50);
		deque.add(60);
		int[] array = new int[deque.size()];
		int i=0;
		for (int taker : deque) {
			array[i]=taker;
			i++;
		}
		for(int taker : array) {
			System.out.println(taker);
			try {
				Thread.sleep(2000);
			} catch (InterruptedException e) {
				e.printStackTrace();
			}
		}
		Iterator<Integer> mouse = deque.iterator();
		while(mouse.hasNext()) {
			System.out.println(mouse.next());
		}
	}	
}

