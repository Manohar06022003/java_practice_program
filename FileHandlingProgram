package com.FileHandling;

import java.io.File;
import java.io.FileReader;
import java.io.FileWriter;
import java.io.IOException;
import java.util.Scanner;

class CreateAFile{
	
	void File1() {
		
		try {
			
		File f1= new File("D:\\folder1");
		f1.mkdir();		
		File f2 = new File("D:\\folder1\\file.txt");
		f1.createNewFile();
		
		}
		catch(Exception e) {
			
			e.printStackTrace();
			
		}
	}
}

class WriteTheFile{
	
	Scanner scan = new Scanner (System.in);
	
	void File1()  {
		
		try {
			
			FileWriter f1 = new FileWriter("D:\\folder1\\file.txt");
			System.out.print("Enter your thoughts : " );
			String data = scan.nextLine();
			f1.write(data);
			f1.close();		//f1.close() method ,It automatically call the Flush();
			
		} 
		catch (Exception e) {
			
			e.printStackTrace();
			
		}		
	}
}

class ReaderTheFile{
	
	void File1(){
		
		try {
			
			FileReader f1= new FileReader("D:\\folder1\\file.txt");
			int c=f1.read();
			while(c != -1) {
								
				System.out.print((char)c);
				c=f1.read();
				
		}
	}
		catch(Exception e) {
			
			e.printStackTrace();
			
		}			
	}	
}
public class FileHandling2 {
	
	public static void main(String []args) {
		
		new CreateAFile().File1();	
		new  WriteTheFile().File1();
		new ReaderTheFile().File1();
		
	}
}
