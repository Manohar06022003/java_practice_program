package com.FileHandling;

import java.io.BufferedReader;
import java.io.BufferedWriter;
import java.io.File;
import java.io.FileNotFoundException;
import java.io.FileReader;
import java.io.FileWriter;
import java.io.IOException;
import java.io.PrintWriter;
import java.util.NoSuchElementException;
import java.util.Scanner;

class CreateFile2{
	
	void CreateFile1() {
		
		File f1 = new File("D:\\Folder1");
		f1.mkdir();		
		
		try {
			
			File f2 = new File("D:\\Folder1\\File1.txt");
			f2.createNewFile();
		}
		catch (IOException e) {
			
			e.printStackTrace();
		}		
	}	
}
 
class WriteFile2{
	Scanner scan = new Scanner(System.in);
	
	void WriteFile1() {
		
		try {
			
			FileWriter f1 = new FileWriter("D:\\Folder1\\File1.txt");
			BufferedWriter Bw1 =new BufferedWriter(f1);
			//String s= scan.nextLine();
			System.out.print("Enter s1 : ");
			int s1= scan.nextInt();
			
			Bw1.write(s1);
			Bw1.newLine();
			Bw1.close();
		}
		catch (IOException e) {
			
			e.printStackTrace();
		}
	}
	void PrintWriter1() {
		
		try {
			
			PrintWriter pw = new PrintWriter (new FileWriter("D:\\Folder1\\File1.txt", true));			
			System.out.print("Enter value  a : ");
		
			int a = scan.nextInt();
			
			pw.println(a);
			scan.close();
			pw.close();
			
		} catch (FileNotFoundException a) {
		
			a.printStackTrace();
		}
		catch (IOException e) {
			
			e.printStackTrace();
		}
		catch (NoSuchElementException f) {
			
			f.printStackTrace();
		}
		catch(Exception d) {
			d.printStackTrace();
		}
	}	
}

class ReadFile2{
	
	void ReadFile1() {
		
		try {
			FileReader Reader1 = new FileReader("D:\\Folder1\\File1.txt");
			BufferedReader Reader2 = new BufferedReader(Reader1);
			
			System.out.println(Reader2 .read()); 
							
		} 
		catch (FileNotFoundException e) {
		
			e.printStackTrace();
		}
		catch (IOException e) {
			
			e.printStackTrace();
			
		}
	}
}
public class FileHandling5 {
	public static void main (String[] args) {
		
		new CreateFile2().CreateFile1();
		new WriteFile2().WriteFile1();
		new WriteFile2().PrintWriter1();
		new ReadFile2().ReadFile1();
	}
}
