}
class bankDetails{
	
	private String name;
	private long accNo;
	private long balance=1000;
	
	bankDetails(String name, long accNo){
		
		this.name = name;
		this.accNo = accNo;
		
	}
	String nameHolderGetter() {
		
		return name;
		
	}
	long accNoGetter() {
		
		return accNo;
	}
	long balanceGetter() {
		
		return balance;
	}
	void depositAmount(long balance1) {
		if(balance1 >0) {
			
		balance = balance1+balance;
		System.out.println("Deposited successfully");
		System.out.println("Available balance : " + balanceGetter() );
		
		}
		else {
			System.out.println("Invalid deposit amount .");
		}
		
	}
	void WithDraw(long amount) {
		
		
		if (amount<=balance) {
			
			balance=balance-amount;
			System.out.println("WithDraw is completed");
			System.out.println("Available balance : " + balanceGetter() );
			
		}
		else {
			System.out.println("Insufficent balance");
		}
	}
}

class functionOfBank extends bankDetails{
	
	Scanner scan = new Scanner (System.in);

	functionOfBank(String name, long accNo) {
		super(name, accNo );
		
	}
	
	void deposit() {
		try {
			
			System.out.print("Enter a deposit Amount : ");
			long amount= scan.nextLong();
			depositAmount(amount);
			
		}
		catch(InputMismatchException e) {
			
			e.printStackTrace();
			System.out.println("Enter only numbers");
			
		}
	}
	
	void withDraws() {
		
		try {
			
			System.out.print("Enter  a withDraw amount : ");
			long amount = scan.nextLong();
			WithDraw(amount);
		}
		catch(InputMismatchException a) {
			
			System.out.println("Enter only numbers");
		}
	}
	
	void detailAccountHolder() {
		
		nameHolderGetter();
		accNoGetter();
		balanceGetter();
		
	}
}

class getDetailsAccount extends functionOfBank{
	
	getDetailsAccount(String name, long accNo) {
		
		super(name, accNo );
	
	}

	void depositTransaction() {
		
		 deposit() ;
		 
