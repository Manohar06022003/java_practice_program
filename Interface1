class Calculator1 implements Calculators{
	int a ,b,c;
	
	Calculator1(int a,int b){
		this.a=a;
		this.b=b;
	}
	public int add() {
		c=a+b;
		return c;
	}
	public int sub() {
		c=a-b;
		return c;
	}
	public int mult() {
		c=a*b;
		return c;
	}	
	public float div() {
		c=a/b;
		return c;
	}
}
